NODE_ENV=production
PORT=8080
MONGODB_URI=<from-secret-manager>
FRONTEND_ORIGIN=https://your-frontend-domain.com
COOKIE_DOMAIN=.your-frontend-domain.com
JWT_ACCESS_SECRET=<from-secret-manager>
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
UPLOAD_DIR=uploads
MAX_IMAGE_UPLOAD_MB=3
GEOIP_LOOKUP_ENABLED=false
GEOIP_LOOKUP_URL_TEMPLATE=
GEOIP_LOOKUP_TIMEOUT_MS=1500
GEOIP_CACHE_TTL_HOURS=168
GEOIP_MONITOR_INTERVAL_MS=600000
GEOIP_METRICS_RETENTION_DAYS=30
AUDIT_INLINE_EXPORT_LIMIT=1000
AUDIT_EXPORT_MAX_ROWS=10000
AUDIT_EXPORT_JOB_TTL_HOURS=24
AUDIT_EXPORT_POLL_INTERVAL_MS=3000
GEMINI_API_KEY=<from-secret-manager>
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_ORDER_EXTRACTION_MODEL=gemini-2.5-flash
GEMINI_LIVE_TOKEN_TTL_MINUTES=10
GEMINI_LIVE_NEW_SESSION_TTL_SECONDS=60
WEBHOOK_DELIVERY_TIMEOUT_MS=4000
