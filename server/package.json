{
  "name": "server",
  "version": "1.0.0",
  "description": "Turbo Tll secure backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "docker:build": "docker build -f Dockerfile -t turbotill-api:local .",
    "docker:run": "docker run --rm -p 8080:8080 --env-file .env turbotill-api:local",
    "deploy:cloudrun": "./scripts/deploy-cloud-run.sh",
    "gcp:bootstrap-deploy": "./scripts/gcp-bootstrap-deploy.sh",
    "gcp:service:url": "bash -lc 'gcloud run services describe ${SERVICE_NAME:-turbotill-api} --region ${GCP_REGION:-us-central1} --project ${GCP_PROJECT_ID:?Set GCP_PROJECT_ID} --format=\"value(status.url)\"'",
    "gcp:service:describe": "bash -lc 'gcloud run services describe ${SERVICE_NAME:-turbotill-api} --region ${GCP_REGION:-us-central1} --project ${GCP_PROJECT_ID:?Set GCP_PROJECT_ID}'",
    "gcp:service:logs": "bash -lc 'gcloud run services logs read ${SERVICE_NAME:-turbotill-api} --region ${GCP_REGION:-us-central1} --project ${GCP_PROJECT_ID:?Set GCP_PROJECT_ID} --limit ${LOG_LIMIT:-100}'",
    "gcp:access:check": "./scripts/gcp-access-check.sh",
    "gcp:build:log": "bash -lc 'gcloud builds log --stream ${BUILD_ID:?Set BUILD_ID} --project ${GCP_PROJECT_ID:?Set GCP_PROJECT_ID}'",
    "gcp:console:run": "bash -lc 'echo https://console.cloud.google.com/run?project=${GCP_PROJECT_ID:?Set GCP_PROJECT_ID}'",
    "gcp:console:builds": "bash -lc 'echo https://console.cloud.google.com/cloud-build/builds?project=${GCP_PROJECT_ID:?Set GCP_PROJECT_ID}'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:integration": "node --test --import tsx --test-concurrency=1 tests/**/*.test.ts"
  },
  "keywords": [
    "express",
    "mongodb",
    "typescript",
    "security"
  ],
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.4.0",
    "@types/supertest": "^7.2.0",
    "mongodb-memory-server": "^8.15.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  }
}
